<%- include('partials/header') %>
<div id="screen-auth" class="min-h-screen auth-bg flex items-center justify-center p-4">
  <div class="w-full max-w-md animate-fade-up">
    <!-- Logo -->
    <div class="text-center mb-10">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="relative w-12 h-12">
          <div class="w-12 h-12 rounded-xl border-2 border-neon-green flex items-center justify-center glow-green">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="3" fill="#00FF87"/>
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="#00FF87" stroke-width="1.5" fill="none" stroke-dasharray="4 2"/>
            </svg>
          </div>
        </div>
        <span class="text-2xl font-bold text-white font-display tracking-tight">Node<span class="text-glow-green" style="color:var(--neon-green)">Watch</span></span>
      </div>
      <p class="text-sm text-slate-500 font-mono">// uptime intelligence platform</p>
    </div>

    <!-- Auth Card -->
    <div class="glass-card p-8" style="border-color:rgba(0,255,135,0.15);">
      <!-- Tabs -->
      <div class="flex gap-1 p-1 rounded-lg mb-8" style="background:rgba(255,255,255,0.04);">
        <a href="/auth/login" class="flex-1 py-2.5 rounded-md text-sm font-semibold transition-all text-slate-400 hover:text-slate-200 text-center">Giriş Yap</a>
        <a href="/auth/register" class="flex-1 py-2.5 rounded-md text-sm font-semibold transition-all text-center" style="background:rgba(0,255,135,0.15);color:var(--neon-green);">Kayıt Ol</a>
      </div>

      <!-- Register Form -->
      <form action="/auth/register" method="POST" id="form-register">
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-mono text-slate-500 mb-2 uppercase tracking-wider">Kullanıcı Adı</label>
            <input type="text" name="username" class="glass-input" placeholder="kullanici_adi" required oninput="validateUsername(this)">
          </div>
          <div>
            <label class="block text-xs font-mono text-slate-500 mb-2 uppercase tracking-wider">Şifre</label>
            <input type="password" id="reg-pass" name="password" class="glass-input" placeholder="Güçlü şifre oluştur" required oninput="checkStrength(this.value)">
            <!-- Strength Meter -->
            <div class="mt-2 space-y-1">
              <div class="flex gap-1">
                <div id="s1" class="strength-bar flex-1" style="background:rgba(255,255,255,0.1);"></div>
                <div id="s2" class="strength-bar flex-1" style="background:rgba(255,255,255,0.1);"></div>
                <div id="s3" class="strength-bar flex-1" style="background:rgba(255,255,255,0.1);"></div>
                <div id="s4" class="strength-bar flex-1" style="background:rgba(255,255,255,0.1);"></div>
              </div>
              <div id="strength-label" class="text-xs font-mono text-slate-600"></div>
            </div>
          </div>
          <div>
            <label class="block text-xs font-mono text-slate-500 mb-2 uppercase tracking-wider">Şifre Tekrar</label>
            <input type="password" name="passwordConfirm" class="glass-input" placeholder="••••••••" required>
          </div>
        </div>

        <% if (error) { %>
          <div class="mt-3 p-3 rounded-lg text-sm font-mono" style="background:rgba(255,51,102,0.1);border:1px solid rgba(255,51,102,0.3);color:var(--alert-red);">
            ❌ <%= error %>
          </div>
        <% } %>

        <button type="submit" class="btn-neon-solid w-full mt-6 py-3 text-sm">Hesap Oluştur →</button>
      </form>
    </div>

    <p class="text-center text-xs font-mono text-slate-700 mt-6">© 2026 NodeWatch · v2.1.0 · SSL Şifreli</p>
  </div>
</div>

<script>
function checkStrength(v) {
  const rules = [
    { test: v.length >= 6 },
    { test: /[A-Z]/.test(v) },
    { test: /[0-9]/.test(v) },
    { test: /[!@#$%^&*]/.test(v) }
  ];
  let score = rules.filter(r=>r.test).length;
  const colors = ['','rgba(255,51,102,0.8)','rgba(255,107,53,0.8)','rgba(255,230,0,0.8)','rgba(0,255,135,0.9)'];
  const labels = ['','Zayıf','Orta','İyi','Güçlü'];
  const lblColors = ['','var(--alert-red)','#FF6B35','#FFE600','var(--neon-green)'];
  for(let i=1;i<=4;i++){
    document.getElementById('s'+i).style.background = i <= score ? colors[score] : 'rgba(255,255,255,0.1)';
  }
  const lbl = document.getElementById('strength-label');
  lbl.textContent = v.length > 0 ? labels[score] : '';
  lbl.style.color = v.length > 0 ? lblColors[score] : '';
}

function validateUsername(el) {
  const valid = /^[a-zA-Z0-9_]{3,}$/.test(el.value);
  el.style.borderColor = el.value.length > 2 ? (valid ? 'rgba(0,255,135,0.5)' : 'rgba(255,51,102,0.5)') : '';
}
</script>
<%- include('partials/footer') %>
