# Server Configuration
PORT=3000
SESSION_SECRET=your_session_secret_here

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=nodewatch

# Security & Cryptography Configuration (AES-256-CBC)
# ENCRYPTION_KEY must be exactly 32 characters
ENCRYPTION_KEY=your_32_character_hex_key_here
# ENCRYPTION_IV must be exactly 16 characters
ENCRYPTION_IV=your_16_char_iv_here

# Default Superadmin Configuration
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=adminpassword

# Default limits for new users
DEFAULT_MONITOR_LIMIT=5
